# Database
DATABASE_URL="postgresql://username:password@localhost:5432/bible_rankings?schema=public"

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Server
PORT=3001
NODE_ENV="development"

# CORS (comma-separated; Vercel *.vercel.app origins are allowed automatically)
CORS_ORIGIN="http://localhost:5173"

# Admin emails (comma-separated, matched case-insensitively)
ADMIN_EMAILS=admin@example.com
