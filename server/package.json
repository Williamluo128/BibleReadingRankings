{
  "name": "@bible-rankings/server",
  "version": "1.0.0",
  "description": "Bible Reading Rankings API Server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && (tsc || true) && tsc-alias",
    "build:vercel": "prisma generate && node scripts/build-vercel.mjs",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:import-bible": "tsx src/scripts/import-bible.ts"
  },
  "dependencies": {
    "@bible-rankings/shared": "*",
    "@prisma/client": "^5.7.0",
    "@supabase/supabase-js": "^2.108.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.16",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.9.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.53.0",
    "prisma": "^5.7.0",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.6.0",
    "typescript": "^5.2.2"
  }
}
