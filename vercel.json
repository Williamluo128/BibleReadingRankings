{
  "buildCommand": "npm run build:shared && npm run build:server && npm run build:client",
  "outputDirectory": "client/dist",
  "framework": null,
  "installCommand": "npm install",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "server/dist/**,server/prisma/**,server/node_modules/.prisma/**,node_modules/.prisma/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
