{
  "buildCommand": "npm run build",
  "outputDirectory": "client/dist",
  "framework": null,
  "installCommand": "npm install",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "api/handler.cjs,server/prisma/schema.prisma,node_modules/.prisma/**,node_modules/@prisma/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
